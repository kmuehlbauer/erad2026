it":true,"key":"rDrGHGA3YP"}],"key":"HjmprmF2S4"},{"type":"block","kind":"notebook-code","children":[{"type":"code","lang":"python","executable":true,"value":"import os\nimport urllib.request\nfrom pathlib import Path\n\n# Set the URL for the cloud\nURL = \"https://js2.jetstream-cloud.org:8001/\"\npath = \"pythia/radar/erad2024/baltrad/baltrad_short_course/\"\n!mkdir -p data\nfiles = [\n    \"seang.h5\",\n    \"searl.h5\",\n    \"sease.h5\",\n    \"sehud.h5\",\n    \"sekir.h5\",\n    \"sekkr.h5\",\n    \"selek.h5\",\n    \"selul.h5\",\n    \"seosu.h5\",\n    \"sevar.h5\",\n    \"sevil.h5\",\n]\nfor file in files:\n    file0 = os.path.join(path, file)\n    name = os.path.join(\"data\", Path(file).name)\n    if not os.path.exists(name):\n        print(f\"downloading, {name}\")\n        urllib.request.urlretrieve(\n            f\"{URL}{file0}\", os.path.join(\"data\", Path(file).name)\n        )","key":"UioliwFutW"},{"type":"outputs","id":"BBBndwsk0qO9o7DdurdLx","children":[],"key":"xesG66KHQe"}],"key":"bQQMhw4IQb"},{"type":"block","children":[{"type":"heading","depth":2,"position":{"start":{"line":72,"column":1},"end":{"line":72,"column":1}},"children":[{"type":"text","value":"Verify from Python the number of CPU cores at our disposal","position":{"start":{"line":72,"column":1},"end":{"line":72,"column":1}},"key":"DW1TR0onNU"}],"identifier":"verify-from-python-the-number-of-cpu-cores-at-our-disposal","label":"Verify from Python the number of CPU cores at our disposal","html_id":"verify-from-python-the-number-of-cpu-cores-at-our-disposal","implicit":true,"key":"dBuD4nA5vM"}],"key":"DScrdHy6z0"},{"type":"block","kind":"notebook-code","children":[{"type":"code","lang":"python","executable":true,"value":"import multiprocessing\n\nprint(\"We have %i cores to play with!\" % multiprocessing.cpu_count())","key":"MESyHkcjBx"},{"type":"outputs","id":"wybpBCsi7DlzTSjdJlO9c","children":[{"type":"output","children":[],"jupyter_data":{"output_type":"stream","name":"stdout","text":"We have 4 cores to play with!\n"},"key":"nMcX6pXloA"}],"key":"HSUljIbjh2"}],"key":"oDT91jcqyo"},{"type":"block","children":[{"type":"paragraph","position":{"start":{"line":80,"column":1},"end":{"line":80,"column":1}},"children":[{"type":"text","value":"Yay! Now we’re going to set up some rudimentary functionality that will allow us to distribute a processing load among our cores.","position":{"start":{"line":80,"column":1},"end":{"line":80,"column":1}},"key":"TcKnGPs0BX"}],"key":"pFCTeqglUG"}],"key":"QloPrGCucD"},{"type":"block","position":{"start":{"line":82,"column":1},"end":{"line":82,"column":1}},"children":[{"type":"heading","depth":2,"position":{"start":{"line":84,"column":1},"end":{"line":84,"column":1}},"children":[{"type":"text","value":"Define a generator","position":{"start":{"line":84,"column":1},"end":{"line":84,"column":1}},"key":"UsreWUm2vZ"}],"identifier":"define-a-generator","label":"Define a generator","html_id":"define-a-generator","implicit":true,"key":"frvdMq3H3R"}],"key":"AKDYwMWkMh"},{"type":"block","kind":"notebook-code","children":[{"type":"code","lang":"python","executable":true,"value":"import os\nimport _raveio, odc_polarQC\n\n# Specify the processing chain\nodc_polarQC.algorithm_ids = [\n    \"ropo\",\n    \"beamb\",\n    \"radvol-att\",\n    \"radvol-broad\",\n    \"rave-overshooting\",\n    \"qi-total\",\n]\n\n\n# Run processing chain on a single file. Return an output file string.\ndef generate(file_string):\n    rio = _raveio.open(file_string)\n\n    pvol = rio.object\n    pvol = odc_polarQC.QC(pvol)\n    rio.object = pvol\n\n    # Derive an output file name\n    path, fstr = os.path.split(file_string)\n    ofstr = os.path.join(path, \"qc_\" + fstr)\n\n    rio.save(ofstr)\n    return ofstr","key":"yqmvbYQm95"},{"type":"outputs","id":"fxwJGBvszkryfuqACzur4","children":[],"key":"kWGngxtGXa"}],"key":"V2Spya4Dbc"},{"type":"block","children":[{"type":"heading","depth":2,"position":{"start":{"line":117,"column":1},"end":{"line":117,"column":1}},"children":[{"type":"text","value":"Feed the generator, sequentially","position":{"start":{"line":117,"column":1},"end":{"line":117,"column":1}},"key":"y1inAvuvBL"}],"identifier":"feed-the-generator-sequentially","label":"Feed the generator, sequentially","html_id":"feed-the-generator-sequentially","implicit":true,"key":"USe6FPnAN4"}],"key":"XgPNvX4Xv2"},{"type":"block","kind":"notebook-code","children":[{"type":"code","lang":"python","executable":true,"value":"import glob, time\n\nifstrs = glob.glob(\"data/se*.h5\")\nbefore = time.time()\nfor fstr in ifstrs:\n    print(fstr, generate(fstr))\nafter = time.time()\n\nprint(\"Processing time: %3.2f seconds\" % (after - before))","key":"ZAq71ijECD"},{"type":"outputs","id":"cI7URuU1j5-w0MEap29vv","children":[{"type":"output","children":[],"jupyter_data":{"output_type":"stream","name":"stdout","text":"data/sevar.h5 data/qc_sevar.h5\n"},"key":"P7ipcmLeZv"},{"type":"output","children":[],"jupyter_data":{"output_type":"stream","name":"stdout","text":"data/sehud.h5 data/qc_sehud.h5\n"},"key":"Trs6ISkBLC"},{"type":"output","children":[],"jupyter_data":{"output_type":"stream","name":"stdout","text":"data/sease.h5 data/qc_sease.h5\n"},"key":"NfbHZGYUZx"},{"type":"output","children":[],"jupyter_data":{"output_type":"stream","name":"stdout","text":"data/seang.h5 data/qc_seang.h5\n"},"key":"eQ3Emx91m8"},{"type":"output","children":[],"jupyter_data":{"output_type":"stream","name":"stdout","text":"data/sekkr.h5 data/qc_sekkr.h5\n"},"key":"pQkR6f277f"},{"type":"output","children":[],"jupyter_data":{"output_type":"stream","name":"stdout","text":"data/sekir.h5 data/qc_sekir.h5\n"},"key":"mJDgPsQB9l"},{"type":"output","children":[],"jupyter_data":{"output_type":"stream","name":"stdout","text":"data/seosu.h5 data/qc_seosu.h5\n"},"key":"kNki6zFuN2"},{"type":"output","children":[],"jupyter_data":{"output_type":"stream","name":"stdout","text":"data/searl.h5 data/qc_searl.h5\n"},"key":"pCAn6G3epM"},{"type":"output","children":[],"jupyter_data":{"output_type":"stream","name":"stdout","text":"data/selek.h5 data/qc_selek.h5\n"},"key":"E0JzIUq4DM"},{"type":"output","children":[],"jupyter_data":{"output_type":"stream","name":"stdout","text":"data/selul.h5 data/qc_selul.h5\n"},"key":"Pq13WQrQgS"},{"type":"output","children":[],"jupyter_data":{"output_type":"stream","name":"stdout","text":"data/sevil.h5 data/qc_sevil.h5\nProcessing time: 5.32 seconds\n"},"key":"ZJChRGIyXb"}],"key":"mabZ6LnZOv"}],"key":"hLErAWmdQ8"},{"type":"block","children":[{"type":"paragraph","position":{"start":{"line":131,"column":1},"end":{"line":131,"column":1}},"children":[{"type":"text","value":"Mental note: repeat once!","position":{"start":{"line":131,"column":1},"end":{"line":131,"column":1}},"key":"zrBX9YG5wT"}],"key":"UkMYEKe5Jn"}],"key":"Ip2cgrLdVq"},{"type":"block","position":{"start":{"line":133,"column":1},"end":{"line":133,"column":1}},"children":[{"type":"heading","depth":2,"position":{"start":{"line":135,"column":1},"end":{"line":135,"column":1}},"children":[{"type":"text","value":"Multiprocess the generator","position":{"start":{"line":135,"column":1},"end":{"line":135,"column":1}},"key":"Qfryxxjgzr"}],"identifier":"multiprocess-the-generator","label":"Multiprocess the generator","html_id":"multiprocess-the-generator","implicit":true,"key":"RfDxpgbOoC"}],"key":"yuKvfJcqQ4"},{"type":"block","kind":"notebook-code","children":[{"type":"code","lang":"python","executable":true,"value":"# Both input and output are a list of file strings\ndef multi_generate(fstrs, procs=None):\n    pool = multiprocessing.Pool(\n        procs\n    )  # Pool of processors. Defaults to all available logical cores\n\n    results = []\n    # chunksize=1 means feed a process a new job as soon as the process is idle.\n    # In our case, this restricts the queue to one \"dispatcher\" which is faster.\n    r = pool.map_async(generate, fstrs, chunksize=1, callback=results.append)\n    r.wait()\n\n    return results[0]","key":"r6gcp4jCW8"},{"type":"outputs","id":"Gluavhvzfs_aQSsMhwNyy","children":[],"key":"RG2z7ICkxc"}],"key":"lu5dRTj5QF"},{"type":"block","children":[{"type":"heading","depth":2,"position":{"start":{"line":153,"column":1},"end":{"line":153,"column":1}},"children":[{"type":"text","value":"Feed the monster, asynchronously!","position":{"start":{"line":153,"column":1},"end":{"line":153,"column":1}},"key":"goqJDAFd81"}],"identifier":"feed-the-monster-asynchronously","label":"Feed the monster, asynchronously!","html_id":"feed-the-monster-asynchronously","implicit":true,"key":"l1iSQH01no"}],"key":"e3I2LoUDdl"},{"type":"block","kind":"notebook-code","children":[{"type":"code","lang":"python","executable":true,"value":"before = time.time()\nofstrs = multi_generate(ifstrs)\nafter = time.time()\n\nprint(\"Processing time: %3.2f seconds\" % (after - before))","key":"wAcgkVa8md"},{"type":"outputs","id":"kNCx90wnfLyW1-VuD78AO","children":[{"type":"output","children":[],"jupyter_data":{"output_type":"stream","name":"stdout","text":"Processing time: 2.43 seconds\n"},"key":"b6dy7ixXym"}],"key":"FvRmLzs6Jx"}],"key":"ZWvIGVCxxu"},{"type":"block","children":[],"key":"rtuyG7AgdB"},{"type":"block","kind":"notebook-code","children":[{"type":"code","lang":"python","executable":true,"value":"","key":"fSqFgOnCPC"},{"type":"outputs","id":"mYsQ1VAriwkGq3nGOjw07","children":[],"key":"OmjKlPcmGK"}],"key":"yJbC95eUKZ"}],"key":"QX9mp1oBUH"},"references":{"cite":{"order":[],"data":{}}},"footer":{"navigation":{"prev":{"title":"Quality Control using DR","url":"/notebooks/baltrad/baltrad-short-course/baltrad-drqc","group":"BALTRAD"},"next":{"title":"Compositing","url":"/notebooks/baltrad/baltrad-short-course/baltrad-compositing","group":"BALTRAD"}}},"domain":"http://localhost:3000"}